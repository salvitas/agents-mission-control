{
  "mcpServers": {
    "ha-mcp": {
      "command": "uvx",
      "args": [
        "ha-mcp@latest"
      ],
      "env": {
        "HOMEASSISTANT_URL": "http://192.168.8.128:8123",
        "HOMEASSISTANT_TOKEN": "${HOMEASSISTANT_TOKEN}"
      }
    },
    "phantom": {
      "command": "npx",
      "args": [
        "-y",
        "@phantom/mcp-server"
      ],
      "env": {
        "PHANTOM_APP_ID": "${PHANTOM_APP_ID}"
      }
    },
    "singapore-transport": {
      "command": "python3",
      "args": [
        "/Users/salva/.openclaw/workspace/projects/mcp-lta-datamall/server.py"
      ],
      "env": {
        "LTA_DATAMALL_API_KEY": "${LTA_DATAMALL_API_KEY}",
        "TRANSIT_STATE_PATH": "/Users/salva/.openclaw/workspace/tmp/singapore-transport/monitors.json"
      }
    }
  },
  "imports": []
}
